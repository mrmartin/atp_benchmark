{
  "_comment": "Frozen OpenCode config for the DeepSeek V4 Pro runner. Pre-registered alongside the harness; do not edit after harness-sealed commit.",
  "model": "openrouter/deepseek/deepseek-v4-pro",
  "providers": {
    "openrouter": {
      "apiKeyEnv": "OPENROUTER_API_KEY",
      "baseUrlEnv": "OPENROUTER_BASE_URL"
    }
  },
  "reasoning": "xhigh",
  "autoCompact": false,
  "temperature": 0.8,
  "maxOutputTokens": 200000,
  "tools": {
    "mcp": {
      "atp-mcp-lean": {
        "command": "atp-mcp-lean",
        "args": []
      }
    }
  }
}
